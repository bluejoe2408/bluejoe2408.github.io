---
import { getCollection } from 'astro:content';
import { Picture } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortByDate, filterPublished } from '../../lib/content';
const trips = sortByDate(filterPublished(await getCollection('travel')));
---
<BaseLayout title="Travel">
  <header class="mb-12 border-b border-neutral-200 pb-8 dark:border-neutral-800">
    <h1 class="text-4xl font-bold tracking-tight text-neutral-900 dark:text-neutral-50">Travel</h1>
    <p class="mt-3 text-neutral-500 dark:text-neutral-400">Places I have wandered, captured along the way.</p>
  </header>
  {trips.length === 0 ? (
    <div class="rounded-xl border border-dashed border-neutral-300 bg-white/50 px-6 py-16 text-center dark:border-neutral-700 dark:bg-neutral-900/30">
      <p class="font-medium text-neutral-700 dark:text-neutral-300">No trips yet</p>
      <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Travel logs are on the way — check back soon.</p>
    </div>
  ) : (
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {trips.map(t => (
        <a href={`/travel/${t.id}`} class="group block overflow-hidden rounded-xl border border-neutral-200 bg-white shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:border-accent-400/70 hover:shadow-md dark:border-neutral-800 dark:bg-neutral-900/50 dark:hover:border-accent-500/50">
          <div class="overflow-hidden">
            <Picture src={t.data.cover} alt={t.data.title} widths={[480, 960]} formats={['avif','webp']} fallbackFormat="jpg" loading="lazy" class="aspect-video w-full object-cover transition-transform duration-300 group-hover:scale-105" />
          </div>
          <div class="p-4">
            <div class="font-semibold tracking-tight text-neutral-900 dark:text-neutral-50">{t.data.title}</div>
            {t.data.location && <div class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">{t.data.location}</div>}
          </div>
        </a>
      ))}
    </div>
  )}
</BaseLayout>
