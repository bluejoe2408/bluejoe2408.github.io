---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortByDate, filterPublished } from '../../lib/content';
const posts = sortByDate(filterPublished(await getCollection('tech')));
// 按 category 分组（每篇取首个 category，缺省归 'Misc'）
const groups = new Map<string, typeof posts>();
for (const p of posts) {
  const key = p.data.categories[0] ?? 'Misc';
  groups.set(key, [...(groups.get(key) ?? []), p]);
}
---
<BaseLayout title="Tech">
  <header class="mb-12 border-b border-neutral-200 pb-8 dark:border-neutral-800">
    <h1 class="text-4xl font-bold tracking-tight text-neutral-900 dark:text-neutral-50">Tech</h1>
    <p class="mt-3 text-neutral-500 dark:text-neutral-400">Notes, experiments, and things I learned along the way.</p>
  </header>
  {[...groups.entries()].map(([cat, items]) => (
    <section class="mb-12">
      <h2 class="mb-4 flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">
        <span class="h-1 w-4 rounded-full bg-accent-500"></span>
        {cat}
      </h2>
      <ul class="divide-y divide-neutral-200 dark:divide-neutral-800">
        {items.map(p => (
          <li>
            <a href={`/tech/${p.id}`} class="group flex flex-wrap items-baseline gap-x-3 gap-y-1 py-3 transition-all duration-200 hover:translate-x-1">
              <span class="font-medium text-neutral-800 transition-colors group-hover:text-accent-600 dark:text-neutral-100 dark:group-hover:text-accent-400">{p.data.title}</span>
              {p.data.tags.map(t => <span class="font-mono text-xs text-neutral-400 dark:text-neutral-500">#{t}</span>)}
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>
