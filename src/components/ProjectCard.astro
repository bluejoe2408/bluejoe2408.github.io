---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
interface Props { project: CollectionEntry<'portfolio'> }
const { project } = Astro.props;
const { title, summary, thumbnail, tech, links } = project.data;
---
<div class="group flex flex-col overflow-hidden rounded-xl border border-neutral-200 bg-white p-4 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:border-accent-400/70 hover:shadow-md dark:border-neutral-800 dark:bg-neutral-900/50 dark:hover:border-accent-500/50">
  <Picture src={thumbnail} alt={title} widths={[400, 800]} formats={['avif','webp']} fallbackFormat="jpg" loading="lazy" class="aspect-video w-full rounded-lg object-cover" />
  <h3 class="mt-3 font-semibold tracking-tight text-neutral-900 dark:text-neutral-50">{title}</h3>
  <p class="mt-1 text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">{summary}</p>
  <div class="mt-3 flex flex-wrap gap-1.5">{tech.map(t => <span class="rounded-md bg-neutral-100 px-2 py-0.5 font-mono text-xs text-neutral-600 transition-colors group-hover:bg-accent-50 group-hover:text-accent-700 dark:bg-neutral-800 dark:text-neutral-400 dark:group-hover:bg-accent-500/10 dark:group-hover:text-accent-300">{t}</span>)}</div>
  {links && <div class="mt-3 flex gap-4 text-sm">
    {links.github && <a href={links.github} class="font-medium text-accent-600 hover:text-accent-700 dark:text-accent-400 dark:hover:text-accent-300">GitHub →</a>}
    {links.demo && <a href={links.demo} class="font-medium text-accent-600 hover:text-accent-700 dark:text-accent-400 dark:hover:text-accent-300">Demo →</a>}
  </div>}
</div>
